views:
  - type: table
    name: 表格
    filters:
      and:
        - "!ID.isEmpty()"
    order:
      - file.name
      - file.folder
      - 英文名
      - 字段
    sort:
      - property: ID
        direction: ASC
      - property: series
        direction: DESC
      - property: 字段
        direction: DESC
    columnSize:
      file.name: 137
      file.folder: 61
      note.英文名: 130
